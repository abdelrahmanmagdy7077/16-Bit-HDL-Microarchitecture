// Specification Reference: Nisan & Schocken, MIT Press

/**
 * 8-way Or gate: 
 * out = in[0] Or in[1] Or ... Or in[7]
 */
CHIP Or8Way {
    IN in[8];
    OUT out;

    PARTS:
    Or(a=in[0] , b= in[1], out=p0 );
    Or(a=in[2] , b=p0 , out=p1 );
    Or(a=in[3] , b=p1 , out=p2 );
    Or(a=in[4] , b=p2 , out=p3 );
    Or(a=in[5] , b=p3 , out=p4 );
    Or(a=in[6] , b=p4 , out=p5 );
    Or(a=in[7] , b=p5 , out=out );
}