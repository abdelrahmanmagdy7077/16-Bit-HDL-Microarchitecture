// Specification Reference: Nisan & Schocken, MIT Press


// File name: projects/1/And.hdl

/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Nand(a=a , b=a , out=p1 );
    Nand(a=b , b=b , out=p2 );
    Nand(a=p1 , b=b , out=p3 );
    Nand(a=p2 , b=a , out=p4 );
    Nand(a=p3 , b=p4 , out=out );
}