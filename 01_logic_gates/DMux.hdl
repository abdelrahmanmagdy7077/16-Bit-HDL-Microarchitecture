// Specification Reference: Nisan & Schocken, MIT Press


// File name: projects/1/DMux.hdl

/**
 * Demultiplexor:
 * [a, b] = [in, 0] if sel = 0
 *          [0, in] if sel = 1
 */
CHIP DMux {
    IN in, sel;
    OUT a, b;

    PARTS:
    Nand(a=sel  , b=sel , out=p1 );
    Nand(a=sel , b=in , out=p2 );
    Nand(a=in , b=p1 , out=p3 );
    Nand(a=p3, b=p3, out=a );
    Nand(a=p2 , b=p2 , out=b );
}